pipeline {
    agent any
 
    environment {
        IMAGE_NAME = "springboot-app"
        AWS_ACCOUNT_ID = "<AWS_ACCOUNT_ID>"
        AWS_REGION = "<AWS_REGION>"
        ECR_REPO = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${IMAGE_NAME}"
        IMAGE_TAG = "${BUILD_NUMBER}"
        SONAR_HOME = tool "SonarScanner"
    }
 
    stages {
 
        stage('Checkout Application') {
            steps {
                git branch: 'main',
                url: 'https://github.com/sathishk1993/Devops.git'
            }
        }
 
        stage('Build') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }
 
        stage('Unit Test') {
            steps {
                sh 'mvn test'
            }
        }
 
        stage('SonarQube Scan') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh '''
                    mvn sonar:sonar \
                    -Dsonar.projectKey=springboot-app \
                    -Dsonar.projectName=springboot-app
                    '''
                }
            }
        }
 
        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
 
        stage('Trivy File Scan') {
            steps {
                sh 'trivy fs .'
            }
        }
 
        stage('Docker Build') {
            steps {
                sh """
                docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .
                """
            }
        }
 
        stage('Trivy Image Scan') {
            steps {
                sh """
                trivy image ${IMAGE_NAME}:${IMAGE_TAG}
                """
            }
        }
 
        stage('Push Image to ECR') {
            steps {
                sh """
                aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
 
                docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${ECR_REPO}:${IMAGE_TAG}
 
                docker push ${ECR_REPO}:${IMAGE_TAG}
                """
            }
        }
 
        stage('Update Manifest Repository') {
            steps {
                dir('manifest-repo') {
                    git branch: 'main',
                    credentialsId: 'github-creds',
                    url: 'https://github.com/<username>/<manifest-repo>.git'
 
                    sh """
                    sed -i 's|image: .*|image: ${ECR_REPO}:${IMAGE_TAG}|g' deployment.yaml
 
                    git config user.name "Jenkins"
                    git config user.email "jenkins@example.com"
 
                    git add deployment.yaml
                    git commit -m "Updated image to ${IMAGE_TAG}" || true
                    git push origin main
                    """
                }
            }
        }
    }
 
    post {
        always {
            cleanWs()
        }
    }
}
post {
    success {
        emailext(
            subject: "SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
            body: "Deployment completed successfully.",
            to: "team@example.com"
        )
    }
    failure {
        emailext(
            subject: "FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
            body: "Deployment failed. Check Jenkins console logs.",
            to: "team@example.com"
        )
    }
    always {
        cleanWs()
    }
}


The Jenkins Master only manages and schedules jobs. The Jenkins Agent performs the actual build and scan tasks. 
SonarQube runs on a separate server because it uses significant CPU and memory, and
multiple projects can use the same SonarQube server."
